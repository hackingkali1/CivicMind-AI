rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOfficial() {
      return signedIn() && request.auth.token.role in ['official', 'admin'];
    }

    match /issues/{issueId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOfficial()
        || request.resource.data.diff(resource.data).changedKeys().hasOnly(['citizenSignals', 'updatedAt']);
    }

    match /reports/{reportId} {
      allow read: if isOfficial() || resource.data.citizenId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.citizenId == request.auth.uid;
      allow update: if isOfficial();
    }

    match /departments/{departmentId} {
      allow read: if signedIn();
      allow write: if isOfficial();
    }

    match /wards/{wardId} {
      allow read: if signedIn();
      allow write: if isOfficial();
    }

    match /agentAudits/{auditId} {
      allow read: if isOfficial();
      allow write: if false;
    }
  }
}
